# Hugging Face Inference API token (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here

# DeepL API key (https://www.deepl.com/account/summary)
DEEPL_KEY=your_deepl_key_here

# Optional: override the Whisper model (default: openai/whisper-large-v3-turbo)
# WHISPER_MODEL=openai/whisper-large-v3-turbo

# Optional: server port (default 5000)
# PORT=5000
